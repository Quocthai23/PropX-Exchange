generator client {
  provider = "prisma-client-js"
}

datasource db {
  // MariaDB is supported under Prisma's "mysql" connector; runtime uses driver adapter.
  provider = "mysql"
}

enum UserRole {
  INVESTOR
  ADMIN
}

enum UserStatus {
  ACTIVE
  DELETED
  BANNED
}

enum KycStatus {
  NONE
  PENDING
  APPROVING
  APPROVED
  REJECTED
}

enum OrderSide {
  BUY
  SELL
}

enum OrderType {
  MARKET
  LIMIT
}

enum OrderStatus {
  PENDING
  OPEN
  PARTIALLY_FILLED
  FILLED
  CANCELLED
  REJECTED
}

enum TransactionType {
  DEPOSIT
  WITHDRAW
  TRANSFER
  TRADE_BUY
  TRADE_SELL
  DIVIDEND
  FEE
  MINT // When issuing new RWA tokens
  BURN // When burning tokens for redemption
  DIVIDEND_CLAIM
  COMMISSION
}

enum TransactionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum AssetTradingStatus {
  OPEN
  PAUSED
  CLOSED
}

enum OnboardingStatus {
  PENDING
  APPRAISING // Actual appraising in progress
  APPROVED // Approved, waiting for tokenization
  REJECTED
  PROCESSING // Calling Blockchain (Queue)
  TOKENIZED // Successfully minted token
}

enum RedemptionStatus {
  PENDING
  PROCESSING_LEGAL // Processing legal name transfer
  COMPLETED // Name transferred, Token burned
  REJECTED
}

enum ProposalStatus {
  ACTIVE
  PASSED
  REJECTED
  EXECUTED
}

enum PostStatus {
  PUBLISHED
  HIDDEN
  BANNED
}

model AssetCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?  @db.Text
  icon        String?
  isActive    Boolean  @default(true)
  assets      Asset[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id                      String                       @id @default(uuid())
  email                   String                       @unique
  walletAddress           String?                      @unique
  username                String?                      @unique
  avatar                  String?
  role                    UserRole                     @default(INVESTOR)
  kycStatus               KycStatus                    @default(NONE)
  refreshTokenHash        String?                      @db.Text
  refreshTokenExpiresAt   DateTime?
  supportTickets          SupportTicket[]              @relation("SupportTicketOwner")
  sentTicketMessages      TicketMessage[]              @relation("TicketMessageSender")
  buyerTrades             Trade[]                      @relation("BuyerTrades")
  sellerTrades            Trade[]                      @relation("SellerTrades")
  dividendClaims          DividendClaim[]
  balances                Balance[]
  orders                  Order[]
  transactions            Transaction[]
  kycRecord               KycRecord?
  approvedKycRecords      KycRecord[]                  @relation("KycApprover")
  auditLogs               AuditLog[]                   @relation("AuditLogPerformer")
  accounts                Account[]
  notifications           Notification[]
  posts                   Post[]
  devices                 UserDevice[]
  readGlobalNotifications UserReadGlobalNotification[]
  postLikes               PostLike[]
  comments                Comment[]
  postBookmarks           PostBookmark[]
  commissionRewards       CommissionReward[]           @relation("UserCommissionRewards")
  sourceCommissionRewards CommissionReward[]           @relation("SourceCommissionRewards")

  // New fields for profile
  gender                  String?
  bio                     String?                  @db.Text
  coverAvatar             String?
  displayName             String?
  referenceCode           String?                  @unique
  referredBy              String?
  referrer                User?                    @relation("UserReferrals", fields: [referredBy], references: [id])
  referrals               User[]                   @relation("UserReferrals")
  passwordHash            String?                  @db.Text
  enabledMfa              Boolean                  @default(false)
  mfaSecret               String?                  @db.Text
  status                  UserStatus               @default(ACTIVE)
  notificationPreferences Json?
  deviceSessions          DeviceSession[]
  favoriteAssets          FavoriteAsset[]
  outgoingRelations       UserRelation[]           @relation("OutgoingRelations")
  incomingRelations       UserRelation[]           @relation("IncomingRelations")
  assetOnboardingRequests AssetOnboardingRequest[]
  assetRedemptionRequests AssetRedemptionRequest[]
  daoProposalsProposed    DaoProposal[]            @relation("DaoProposalProposer")
  proposalVotes           ProposalVote[]

  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  daoVotingSnapshots DaoVotingSnapshot[]
  postReports        PostReport[]
}

model FavoriteAsset {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  assetId   String
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, assetId])
}

model UserRelation {
  id          String   @id @default(uuid())
  fromUserId  String
  fromUser    User     @relation("OutgoingRelations", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUserId    String
  toUser      User     @relation("IncomingRelations", fields: [toUserId], references: [id], onDelete: Cascade)
  isFollowing Boolean  @default(false)
  isBlocking  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([fromUserId, toUserId])
}

model SupportTicket {
  id              String              @id @default(uuid())
  userId          String
  user            User                @relation("SupportTicketOwner", fields: [userId], references: [id])
  subject         String
  title           String?
  status          SupportTicketStatus @default(OPEN)
  category        String?
  priority        String?
  assignedAdminId String?
  messages        TicketMessage[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([userId, status, createdAt])
}

model TicketMessage {
  id        String        @id @default(uuid())
  ticketId  String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id])
  senderId  String
  sender    User          @relation("TicketMessageSender", fields: [senderId], references: [id])
  content   String        @db.Text
  attachments Json?
  createdAt DateTime      @default(now())

  @@index([ticketId, createdAt])
}

model Otp {
  id        String   @id @default(uuid())
  email     String   @unique
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model DeviceSession {
  id                    String   @id @default(uuid())
  userId                String
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceId              String
  refreshTokenHash      String   @db.Text
  refreshTokenExpiresAt DateTime
  userAgent             String?
  ipAddress             String?
  lastSeenAt            DateTime @default(now())
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([userId, deviceId])
  @@index([userId, refreshTokenExpiresAt])
}

model KycRecord {
  id                 String    @id @default(uuid())
  userId             String    @unique
  user               User      @relation(fields: [userId], references: [id])
  fullName           String
  dob                DateTime
  idNumber           String    @unique
  idFrontImg         String
  idBackImg          String
  selfieImg          String
  status             KycStatus @default(PENDING)
  onChainWhitelisted Boolean   @default(false)
  whitelistTxHash    String?
  rejectReason       String?
  approvedBy         String?
  approver           User?     @relation("KycApprover", fields: [approvedBy], references: [id])
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model Asset {
  id                    String                   @id @default(uuid())
  contractAddress       String?                  @unique
  txHash                String?                  @unique
  symbol                String                   @unique
  name                  String
  description           String?                  @db.Text
  logo                  String?
  categoryId            String
  category              AssetCategory            @relation(fields: [categoryId], references: [id])
  totalSupply           Decimal
  tokenPrice            Decimal
  referencePrice        Decimal?
  priceBandPercentage   Decimal                  @default(0.07)
  tradingStatus         AssetTradingStatus       @default(OPEN)
  expectedApy           Decimal?
  tokenStandard         String? // VD: "ERC20", "ERC3643"
  spvName               String? // Special Purpose Vehicle - Legal entity holding the real-world asset
  legalDocsIpfs         String? // CID of encrypted, immutable legal docs on IPFS
  auditReportUrl        String? // Link to periodic asset audit report
  isHot                 Boolean                  @default(false)
  isActive              Boolean                  @default(false)
  candlesticks          Candlestick[]
  dividendDistributions DividendDistribution[]
  corporateActions      CorporateAction[]
  valuationSnapshots    AssetValuationSnapshot[]
  trades                Trade[]
  favoriteAssets        FavoriteAsset[]
  balances              Balance[]
  orders                Order[]
  redemptionRequests    AssetRedemptionRequest[]
  daoProposals          DaoProposal[]
  taggedNews            AssetNews[]
  postCashtags          PostCashtag[]
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
}

model Balance {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  assetId      String?
  asset        Asset?   @relation(fields: [assetId], references: [id])
  available    Decimal  @default(0)
  locked       Decimal  @default(0)
  avgCostPrice Decimal?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, assetId])
}

model AssetOnboardingRequest {
  id             String           @id @default(uuid())
  userId         String
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  title          String // Ex: "Vinhomes Smart City Apartment"
  description    String           @db.Text
  location       String? // Asset location
  estimatedValue Decimal // Desired valuation
  legalDocuments Json // Array of URLs to Title deeds, legal documents
  status         OnboardingStatus @default(PENDING)
  adminNotes     String?          @db.Text // Appraisal team notes
  appraisedValue Decimal? // Appraised value after appraisal
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([userId, status, createdAt(sort: Desc)])
}

model AssetRedemptionRequest {
  id                String           @id @default(uuid())
  userId            String
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  assetId           String
  asset             Asset            @relation(fields: [assetId], references: [id])
  tokenQuantity     Decimal // Quantity of tokens for exchange
  status            RedemptionStatus @default(PENDING)
  legalTransferDocs Json? // Signed transfer contract/minutes
  burnTxHash        String? // On-chain Burn token transaction hash
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([userId, status, createdAt(sort: Desc)])
  @@index([assetId, status, createdAt(sort: Desc)])
}

model DaoProposal {
  id           String              @id @default(uuid())
  assetId      String
  asset        Asset               @relation(fields: [assetId], references: [id])
  proposerId   String // Proposal creator (UserId)
  proposer     User                @relation("DaoProposalProposer", fields: [proposerId], references: [id], onDelete: Cascade)
  title        String
  description  String              @db.Text
  snapshotDate DateTime // Voting power snapshot time
  endDate      DateTime // Voting deadline
  status       ProposalStatus      @default(ACTIVE)
  votes        ProposalVote[]
  snapshots    DaoVotingSnapshot[]
  createdAt    DateTime            @default(now())

  @@index([assetId, status, endDate])
  @@index([proposerId, createdAt(sort: Desc)])
}

model DaoVotingSnapshot {
  id          String      @id @default(uuid())
  proposalId  String
  proposal    DaoProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  votingPower Decimal
  createdAt   DateTime    @default(now())

  @@unique([proposalId, userId])
  @@index([proposalId, votingPower(sort: Desc)])
}

model ProposalVote {
  id          String      @id @default(uuid())
  proposalId  String
  proposal    DaoProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  isFor       Boolean // True: For, False: Against
  votingPower Decimal // Voting weight at snapshotDate
  createdAt   DateTime    @default(now())

  @@unique([proposalId, userId])
  @@index([proposalId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
}

model Order {
  id             String      @id @default(uuid())
  userId         String
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  assetId        String
  asset          Asset       @relation(fields: [assetId], references: [id])
  side           OrderSide
  type           OrderType
  price          Decimal?
  quantity       Decimal
  filledQuantity Decimal     @default(0)
  status         OrderStatus
  idempotencyKey String?     @unique
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model Transaction {
  id             String            @id @default(uuid())
  userId         String
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  type           TransactionType
  amount         Decimal
  fee            Decimal           @default(0)
  status         TransactionStatus
  txHash         String?           @unique
  confirmations  Int               @default(0)
  idempotencyKey String?           @unique

  // Gas spike handling fields
  gasPrice         Decimal? // Initial gas price in wei
  lastGasPrice     Decimal? // Latest gas price from speed-up
  speedUpAttempts  Int                 @default(0)
  stuckSince       DateTime? // When transaction got stuck (no confirmations after 1 hour)
  refundStatus     String              @default("NONE") // NONE, PENDING, COMPLETED
  refundTxHash     String? // Hash of refund transaction if processed
  speedUpAttempts_ GasSpeedUpAttempt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GasSpeedUpAttempt {
  id             String      @id @default(uuid())
  transactionId  String
  transaction    Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  previousTxHash String
  newTxHash      String
  oldGasPrice    Decimal // Previous gas price
  newGasPrice    Decimal // New gas price
  gasFeePaid     Decimal // Extra gas fee paid for speed-up
  status         String      @default("PENDING") // PENDING, COMPLETED, FAILED
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model AuditLog {
  id          String   @id @default(uuid())
  entity      String
  entityId    String
  action      String
  performedBy String
  performer   User     @relation("AuditLogPerformer", fields: [performedBy], references: [id])
  details     String?  @db.Text
  createdAt   DateTime @default(now())
}

enum CorporateActionType {
  DIVIDEND
  DEPRECIATION
  LIQUIDATION
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model CorporateAction {
  id            String              @id @default(uuid())
  assetId       String
  asset         Asset               @relation(fields: [assetId], references: [id])
  type          CorporateActionType
  amount        Decimal
  recordDate    DateTime
  executionDate DateTime
  status        String
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}

model DividendDistribution {
  id           String          @id @default(uuid())
  assetId      String
  asset        Asset           @relation(fields: [assetId], references: [id])
  totalAmount  Decimal
  snapshotDate DateTime
  status       String          @default("PENDING") // PENDING, READY_FOR_CLAIM, COMPLETED
  claims       DividendClaim[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

model DividendClaim {
  id             String               @id @default(uuid())
  distributionId String
  distribution   DividendDistribution @relation(fields: [distributionId], references: [id])
  userId         String
  user           User                 @relation(fields: [userId], references: [id])
  amount         Decimal
  status         String               @default("PENDING") // PENDING, CLAIMED
  claimedAt      DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@unique([distributionId, userId])
}

model Candlestick {
  id         String   @id @default(uuid())
  assetId    String
  asset      Asset    @relation(fields: [assetId], references: [id])
  resolution String // VD: "1m", "5m", "15m", "30m", "1h", "1d"
  openTime   DateTime
  open       Decimal
  high       Decimal
  low        Decimal
  close      Decimal
  volume     Decimal
  createdAt  DateTime @default(now())

  @@unique([assetId, resolution, openTime])
  @@index([assetId, resolution, openTime(sort: Desc)])
}

model Trade {
  id               String   @id @default(uuid())
  assetId          String
  asset            Asset    @relation(fields: [assetId], references: [id])
  buyerId          String
  buyer            User     @relation("BuyerTrades", fields: [buyerId], references: [id])
  sellerId         String
  seller           User     @relation("SellerTrades", fields: [sellerId], references: [id])
  price            Decimal
  quantity         Decimal
  settlementStatus String   @default("PENDING") // PENDING, PROCESSING, SETTLED, FAILED
  txHash           String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model NewsArticle {
  id           String      @id @default(uuid())
  source       String
  externalId   String?
  dedupeKey    String      @unique
  title        Json
  summary      Json?
  content      String?     @db.Text
  url          String
  imageUrl     String?
  publishedAt  DateTime
  language     String?
  country      String?
  category     String?
  keywords     String?     @db.Text
  sentiment    String? // BULLISH, BEARISH, NEUTRAL
  impactScore  Int?
  taggedAssets AssetNews[]
  rawPayload   Json?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([source, publishedAt(sort: Desc)])
  @@index([publishedAt(sort: Desc)])
}

model AssetNews {
  newsId  String
  assetId String
  news    NewsArticle @relation(fields: [newsId], references: [id], onDelete: Cascade)
  asset   Asset       @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@id([newsId, assetId])
  @@index([assetId])
}

model AccountType {
  id          String    @id @default(uuid())
  code        String    @unique
  name        String
  description String?   @db.Text
  currency    String    @default("USDT")
  isActive    Boolean   @default(true)
  accounts    Account[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Account {
  id            String      @id @default(uuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountTypeId String
  accountType   AccountType @relation(fields: [accountTypeId], references: [id])
  name          String
  avatar        String?
  status        String      @default("ACTIVE") // ACTIVE, INACTIVE, BANNED
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([userId, accountTypeId])
  @@index([userId, status])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String // "KYC_APPROVED", "KYC_REJECTED", "ORDER_FILLED", etc.
  title     String
  content   String?  @db.Text
  isRead    Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId, isRead, createdAt(sort: Desc)])
}

model Post {
  id        String         @id @default(uuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String?        @db.Text
  mediaUrls Json?
  status    PostStatus     @default(PUBLISHED)
  likes     PostLike[]
  comments  Comment[]
  bookmarks PostBookmark[]
  cashtags  PostCashtag[]
  reports   PostReport[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model PostCashtag {
  postId  String
  post    Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@id([postId, assetId])
  @@index([assetId])
}

model PostReport {
  id        String   @id @default(uuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reason    String   @db.Text
  createdAt DateTime @default(now())

  @@index([postId])
  @@index([userId])
}

model PostLike {
  id        String   @id @default(uuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
}

model Comment {
  id        String   @id @default(uuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PostBookmark {
  id        String   @id @default(uuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
}

model AssetValuationSnapshot {
  id         String   @id @default(uuid())
  assetId    String?
  asset      Asset?   @relation(fields: [assetId], references: [id])
  areaCode   String?
  source     String
  title      String?
  listingUrl String?
  price      Decimal
  currency   String   @default("VND")
  landArea   Decimal?
  pricePerM2 Decimal?
  capturedAt DateTime
  rawPayload Json?
  createdAt  DateTime @default(now())

  @@index([assetId, capturedAt(sort: Desc)])
  @@index([areaCode, capturedAt(sort: Desc)])
  @@index([source, capturedAt(sort: Desc)])
}

model UserDevice {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fcmToken  String   @unique
  deviceOs  String? // iOS, Android, Web
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model GlobalNotification {
  id        String   @id @default(uuid())
  title     String
  content   String?  @db.Text
  type      String   @default("SYSTEM") // SYSTEM, MAINTENANCE, PROMO
  createdAt DateTime @default(now())

  readBy UserReadGlobalNotification[]
}

model UserReadGlobalNotification {
  userId               String
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  globalNotificationId String
  globalNotification   GlobalNotification @relation(fields: [globalNotificationId], references: [id], onDelete: Cascade)
  readAt               DateTime           @default(now())

  @@id([userId, globalNotificationId])
}

enum CommissionEvent {
  TRADE
  PROFIT_SHARE
  YIELD
}

enum CommissionRewardStatus {
  PENDING
  AVAILABLE
  CLAIMED
  REJECTED
}

model CommissionConfig {
  id             String          @id @default(uuid())
  eventType      CommissionEvent @unique
  commissionRate Decimal         // e.g., 0.20 for 20%
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model CommissionReward {
  id               String                 @id @default(uuid())
  userId           String                 // Reward recipient (A)
  user             User                   @relation("UserCommissionRewards", fields: [userId], references: [id], onDelete: Cascade)
  sourceUserId     String                 // Event trigger user (B)
  sourceUser       User                   @relation("SourceCommissionRewards", fields: [sourceUserId], references: [id])
  eventType        CommissionEvent
  amount           Decimal                // Reward amount received
  currency         String                 @default("USDT")
  sourceTxId       String?                // Source transaction ID
  status           CommissionRewardStatus @default(PENDING) // Reward status
  unlockAt         DateTime?              // Allowed claim time (Vesting)
  claimedAt        DateTime?              // Successful claim time
  txHash           String?                // On-chain transaction hash (Claim On-chain)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  @@index([userId, status])
  @@index([sourceUserId])
}
