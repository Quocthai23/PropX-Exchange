generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql" // Or postgresql depending on your project
}

model User {
  id                  String   @id @default(uuid())
  email               String   @unique
  walletAddress       String   @unique
  encryptedPrivateKey String   @db.Text
  username            String?  @unique
  role                String   @default("INVESTOR")
  kycStatus           String   @default("NONE")
  refreshTokenHash    String?  @db.Text
  refreshTokenExpiresAt DateTime?
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Otp {
  id        String   @id @default(uuid())
  email     String   @unique
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model KycRecord {
  id           String   @id @default(uuid())
  userId       String   @unique
  fullName     String
  dob          DateTime
  idNumber     String   @unique
  idFrontImg   String
  idBackImg    String
  selfieImg    String
  status       String   @default("PENDING")
  rejectReason String?
  createdAt    DateTime @default(now())
}

model Asset {
  id              String   @id @default(uuid())
  contractAddress String?  @unique
  txHash          String?  @unique
  symbol          String   @unique
  name            String
  description     String?  @db.Text
  logo            String?
  categoryId      String
  totalSupply     Decimal
  tokenPrice      Decimal
  expectedApy     Decimal?
  isHot           Boolean  @default(false)
  isActive        Boolean  @default(false)
  corporateActions CorporateAction[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Balance {
  id        String   @id @default(uuid())
  userId    String
  assetId   String?
  available Decimal  @default(0)
  locked    Decimal  @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, assetId])
}

model Order {
  id             String   @id @default(uuid())
  userId         String
  assetId        String
  side           String
  type           String
  price          Decimal?
  quantity       Decimal
  filledQuantity Decimal  @default(0)
  status         String
  idempotencyKey String?  @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Transaction {
  id             String   @id @default(uuid())
  userId         String
  type           String
  amount         Decimal
  fee            Decimal  @default(0)
  status         String
  txHash         String?  @unique
  confirmations  Int      @default(0)
  idempotencyKey String?  @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model AuditLog {
  id          String   @id @default(uuid())
  entity      String
  entityId    String
  action      String
  performedBy String
  details     String?  @db.Text
  createdAt   DateTime @default(now())
}

enum CorporateActionType {
  DIVIDEND
  DEPRECIATION
  LIQUIDATION
}

model CorporateAction {
  id            String              @id @default(uuid())
  assetId       String
  asset         Asset               @relation(fields: [assetId], references: [id])
  type          CorporateActionType
  amount        Decimal
  recordDate    DateTime
  executionDate DateTime
  status        String
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}