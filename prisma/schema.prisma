generator client {
  provider = "prisma-client-js"
}

datasource db {
  // MariaDB is supported under Prisma's "mysql" connector; runtime uses driver adapter.
  provider = "mysql"
}

enum UserRole {
  INVESTOR
  ADMIN
}

enum UserStatus {
  ACTIVE
  DELETED
  BANNED
}

enum KycStatus {
  NONE
  PENDING
  APPROVING
  APPROVED
  REJECTED
}

enum OrderSide {
  BUY
  SELL
}

enum OrderType {
  MARKET
  LIMIT
}

enum OrderStatus {
  PENDING
  OPEN
  PARTIALLY_FILLED
  FILLED
  CANCELLED
  REJECTED
}

enum TransactionType {
  DEPOSIT
  WITHDRAW
  TRANSFER
  TRADE_BUY
  TRADE_SELL
  DIVIDEND
  FEE
  MINT // When issuing new RWA tokens
  BURN // When burning tokens for redemption
  DIVIDEND_CLAIM
}

enum TransactionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum AssetTradingStatus {
  OPEN
  PAUSED
  CLOSED
}

enum OnboardingStatus {
  PENDING
  APPRAISING // Đang thẩm định thực tế
  APPROVED // Đã duyệt, chờ token hóa
  REJECTED
  TOKENIZED // Đã mint thành công token
}

enum RedemptionStatus {
  PENDING
  PROCESSING_LEGAL // Đang làm thủ tục sang tên sổ đỏ
  COMPLETED // Đã sang tên, Token đã bị Burn
  REJECTED
}

enum ProposalStatus {
  ACTIVE
  PASSED
  REJECTED
  EXECUTED
}

model AssetCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?  @db.Text
  icon        String?
  isActive    Boolean  @default(true)
  assets      Asset[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id                    String          @id @default(uuid())
  email                 String          @unique
  walletAddress         String?         @unique
  username              String?         @unique
  avatar                String?
  role                  UserRole        @default(INVESTOR)
  kycStatus             KycStatus       @default(NONE)
  refreshTokenHash      String?         @db.Text
  refreshTokenExpiresAt DateTime?
  supportTickets        SupportTicket[] @relation("SupportTicketOwner")
  sentTicketMessages    TicketMessage[] @relation("TicketMessageSender")
  buyerTrades           Trade[]         @relation("BuyerTrades")
  sellerTrades          Trade[]         @relation("SellerTrades")
  dividendClaims        DividendClaim[]
  balances              Balance[]
  orders                Order[]
  transactions          Transaction[]
  kycRecord             KycRecord?
  approvedKycRecords    KycRecord[]     @relation("KycApprover")
  auditLogs             AuditLog[]      @relation("AuditLogPerformer")
  accounts              Account[]
  notifications         Notification[]
  posts                 Post[]
  postLikes             PostLike[]
  comments              Comment[]
  postBookmarks         PostBookmark[]

  // New fields for profile
  gender                  String?
  bio                     String?                  @db.Text
  coverAvatar             String?
  displayName             String?
  referenceCode           String?                  @unique
  referredBy              String?
  referrer                User?                    @relation("UserReferrals", fields: [referredBy], references: [id])
  referrals               User[]                   @relation("UserReferrals")
  passwordHash            String?                  @db.Text
  enabledMfa              Boolean                  @default(false)
  status                  UserStatus               @default(ACTIVE)
  favoriteAssets          FavoriteAsset[]
  outgoingRelations       UserRelation[]           @relation("OutgoingRelations")
  incomingRelations       UserRelation[]           @relation("IncomingRelations")
  assetOnboardingRequests AssetOnboardingRequest[]
  assetRedemptionRequests AssetRedemptionRequest[]
  daoProposalsProposed    DaoProposal[]            @relation("DaoProposalProposer")
  proposalVotes           ProposalVote[]

  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  daoVotingSnapshots DaoVotingSnapshot[]
}

model FavoriteAsset {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  assetId   String
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, assetId])
}

model UserRelation {
  id          String   @id @default(uuid())
  fromUserId  String
  fromUser    User     @relation("OutgoingRelations", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUserId    String
  toUser      User     @relation("IncomingRelations", fields: [toUserId], references: [id], onDelete: Cascade)
  isFollowing Boolean  @default(false)
  isBlocking  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([fromUserId, toUserId])
}

model SupportTicket {
  id              String              @id @default(uuid())
  userId          String
  user            User                @relation("SupportTicketOwner", fields: [userId], references: [id])
  subject         String
  title           String?
  status          SupportTicketStatus @default(OPEN)
  category        String?
  priority        String?
  assignedAdminId String?
  messages        TicketMessage[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([userId, status, createdAt])
}

model TicketMessage {
  id        String        @id @default(uuid())
  ticketId  String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id])
  senderId  String
  sender    User          @relation("TicketMessageSender", fields: [senderId], references: [id])
  content   String        @db.Text
  createdAt DateTime      @default(now())

  @@index([ticketId, createdAt])
}

model Otp {
  id        String   @id @default(uuid())
  email     String   @unique
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model KycRecord {
  id                 String    @id @default(uuid())
  userId             String    @unique
  user               User      @relation(fields: [userId], references: [id])
  fullName           String
  dob                DateTime
  idNumber           String    @unique
  idFrontImg         String
  idBackImg          String
  selfieImg          String
  status             KycStatus @default(PENDING)
  onChainWhitelisted Boolean   @default(false)
  whitelistTxHash    String?
  rejectReason       String?
  approvedBy         String?
  approver           User?     @relation("KycApprover", fields: [approvedBy], references: [id])
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model Asset {
  id                    String                   @id @default(uuid())
  contractAddress       String?                  @unique
  txHash                String?                  @unique
  symbol                String                   @unique
  name                  String
  description           String?                  @db.Text
  logo                  String?
  categoryId            String
  category              AssetCategory            @relation(fields: [categoryId], references: [id])
  totalSupply           Decimal
  tokenPrice            Decimal
  referencePrice        Decimal?
  priceBandPercentage   Decimal                  @default(0.07)
  tradingStatus         AssetTradingStatus       @default(OPEN)
  expectedApy           Decimal?
  tokenStandard         String? // VD: "ERC20", "ERC3643"
  spvName               String? // Special Purpose Vehicle - Pháp nhân đứng tên tài sản ngoài đời
  legalDocsIpfs         String? // CID of encrypted, immutable legal docs on IPFS
  auditReportUrl        String? // Link báo cáo kiểm toán tài sản định kỳ
  isHot                 Boolean                  @default(false)
  isActive              Boolean                  @default(false)
  candlesticks          Candlestick[]
  dividendDistributions DividendDistribution[]
  corporateActions      CorporateAction[]
  valuationSnapshots    AssetValuationSnapshot[]
  trades                Trade[]
  favoriteAssets        FavoriteAsset[]
  balances              Balance[]
  orders                Order[]
  redemptionRequests    AssetRedemptionRequest[]
  daoProposals          DaoProposal[]
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
}

model Balance {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  assetId      String?
  asset        Asset?   @relation(fields: [assetId], references: [id])
  available    Decimal  @default(0)
  locked       Decimal  @default(0)
  avgCostPrice Decimal?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, assetId])
}

model AssetOnboardingRequest {
  id             String           @id @default(uuid())
  userId         String
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  title          String // VD: "Căn hộ Vinhomes Smart City"
  description    String           @db.Text
  location       String? // Vị trí tài sản
  estimatedValue Decimal // Định giá mong muốn
  legalDocuments Json // Mảng URL ảnh Sổ đỏ, giấy tờ pháp lý
  status         OnboardingStatus @default(PENDING)
  adminNotes     String?          @db.Text // Ghi chú của đội thẩm định
  appraisedValue Decimal? // Giá trị định giá sau khi thẩm định
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([userId, status, createdAt(sort: Desc)])
}

model AssetRedemptionRequest {
  id                String           @id @default(uuid())
  userId            String
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  assetId           String
  asset             Asset            @relation(fields: [assetId], references: [id])
  tokenQuantity     Decimal // Số lượng token mang đi quy đổi
  status            RedemptionStatus @default(PENDING)
  legalTransferDocs Json? // Hợp đồng/biên bản chuyển nhượng đã ký
  burnTxHash        String? // Hash giao dịch Burn token on-chain
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([userId, status, createdAt(sort: Desc)])
  @@index([assetId, status, createdAt(sort: Desc)])
}

model DaoProposal {
  id           String              @id @default(uuid())
  assetId      String
  asset        Asset               @relation(fields: [assetId], references: [id])
  proposerId   String // Người tạo đề xuất (UserId)
  proposer     User                @relation("DaoProposalProposer", fields: [proposerId], references: [id], onDelete: Cascade)
  title        String
  description  String              @db.Text
  snapshotDate DateTime // Thời điểm chốt quyền vote
  endDate      DateTime // Hạn chót bỏ phiếu
  status       ProposalStatus      @default(ACTIVE)
  votes        ProposalVote[]
  snapshots    DaoVotingSnapshot[]
  createdAt    DateTime            @default(now())

  @@index([assetId, status, endDate])
  @@index([proposerId, createdAt(sort: Desc)])
}

model DaoVotingSnapshot {
  id          String      @id @default(uuid())
  proposalId  String
  proposal    DaoProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  votingPower Decimal
  createdAt   DateTime    @default(now())

  @@unique([proposalId, userId])
  @@index([proposalId, votingPower(sort: Desc)])
}

model ProposalVote {
  id          String      @id @default(uuid())
  proposalId  String
  proposal    DaoProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  isFor       Boolean // True: Đồng ý, False: Chống
  votingPower Decimal // Trọng số tại snapshotDate
  createdAt   DateTime    @default(now())

  @@unique([proposalId, userId])
  @@index([proposalId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
}

model Order {
  id             String      @id @default(uuid())
  userId         String
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  assetId        String
  asset          Asset       @relation(fields: [assetId], references: [id])
  side           OrderSide
  type           OrderType
  price          Decimal?
  quantity       Decimal
  filledQuantity Decimal     @default(0)
  status         OrderStatus
  idempotencyKey String?     @unique
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model Transaction {
  id             String            @id @default(uuid())
  userId         String
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  type           TransactionType
  amount         Decimal
  fee            Decimal           @default(0)
  status         TransactionStatus
  txHash         String?           @unique
  confirmations  Int               @default(0)
  idempotencyKey String?           @unique

  // Gas spike handling fields
  gasPrice         Decimal? // Initial gas price in wei
  lastGasPrice     Decimal? // Latest gas price from speed-up
  speedUpAttempts  Int                 @default(0)
  stuckSince       DateTime? // When transaction got stuck (no confirmations after 1 hour)
  refundStatus     String              @default("NONE") // NONE, PENDING, COMPLETED
  refundTxHash     String? // Hash of refund transaction if processed
  speedUpAttempts_ GasSpeedUpAttempt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GasSpeedUpAttempt {
  id             String      @id @default(uuid())
  transactionId  String
  transaction    Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  previousTxHash String
  newTxHash      String
  oldGasPrice    Decimal // Previous gas price
  newGasPrice    Decimal // New gas price
  gasFeePaid     Decimal // Extra gas fee paid for speed-up
  status         String      @default("PENDING") // PENDING, COMPLETED, FAILED
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model AuditLog {
  id          String   @id @default(uuid())
  entity      String
  entityId    String
  action      String
  performedBy String
  performer   User     @relation("AuditLogPerformer", fields: [performedBy], references: [id])
  details     String?  @db.Text
  createdAt   DateTime @default(now())
}

enum CorporateActionType {
  DIVIDEND
  DEPRECIATION
  LIQUIDATION
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model CorporateAction {
  id            String              @id @default(uuid())
  assetId       String
  asset         Asset               @relation(fields: [assetId], references: [id])
  type          CorporateActionType
  amount        Decimal
  recordDate    DateTime
  executionDate DateTime
  status        String
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}

model DividendDistribution {
  id           String          @id @default(uuid())
  assetId      String
  asset        Asset           @relation(fields: [assetId], references: [id])
  totalAmount  Decimal
  snapshotDate DateTime
  status       String          @default("PENDING") // PENDING, READY_FOR_CLAIM, COMPLETED
  claims       DividendClaim[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

model DividendClaim {
  id             String               @id @default(uuid())
  distributionId String
  distribution   DividendDistribution @relation(fields: [distributionId], references: [id])
  userId         String
  user           User                 @relation(fields: [userId], references: [id])
  amount         Decimal
  status         String               @default("PENDING") // PENDING, CLAIMED
  claimedAt      DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@unique([distributionId, userId])
}

model Candlestick {
  id         String   @id @default(uuid())
  assetId    String
  asset      Asset    @relation(fields: [assetId], references: [id])
  resolution String // VD: "1m", "5m", "15m", "30m", "1h", "1d"
  openTime   DateTime
  open       Decimal
  high       Decimal
  low        Decimal
  close      Decimal
  volume     Decimal
  createdAt  DateTime @default(now())

  @@unique([assetId, resolution, openTime])
  @@index([assetId, resolution, openTime(sort: Desc)])
}

model Trade {
  id               String   @id @default(uuid())
  assetId          String
  asset            Asset    @relation(fields: [assetId], references: [id])
  buyerId          String
  buyer            User     @relation("BuyerTrades", fields: [buyerId], references: [id])
  sellerId         String
  seller           User     @relation("SellerTrades", fields: [sellerId], references: [id])
  price            Decimal
  quantity         Decimal
  settlementStatus String   @default("PENDING") // PENDING, PROCESSING, SETTLED, FAILED
  txHash           String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model NewsArticle {
  id          String   @id @default(uuid())
  source      String
  externalId  String?
  dedupeKey   String   @unique
  title       String
  summary     String?  @db.Text
  content     String?  @db.Text
  url         String
  imageUrl    String?
  publishedAt DateTime
  language    String?
  country     String?
  category    String?
  keywords    String?  @db.Text
  rawPayload  Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([source, publishedAt(sort: Desc)])
  @@index([publishedAt(sort: Desc)])
}

model AccountType {
  id          String    @id @default(uuid())
  code        String    @unique
  name        String
  description String?   @db.Text
  currency    String    @default("USDT")
  isActive    Boolean   @default(true)
  accounts    Account[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Account {
  id            String      @id @default(uuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountTypeId String
  accountType   AccountType @relation(fields: [accountTypeId], references: [id])
  name          String
  avatar        String?
  status        String      @default("ACTIVE") // ACTIVE, INACTIVE, BANNED
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([userId, accountTypeId])
  @@index([userId, status])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String // "KYC_APPROVED", "KYC_REJECTED", "ORDER_FILLED", etc.
  title     String
  content   String?  @db.Text
  isRead    Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId, isRead, createdAt(sort: Desc)])
}

model Post {
  id        String         @id @default(uuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String?        @db.Text
  mediaUrls Json?
  likes     PostLike[]
  comments  Comment[]
  bookmarks PostBookmark[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model PostLike {
  id        String   @id @default(uuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
}

model Comment {
  id        String   @id @default(uuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PostBookmark {
  id        String   @id @default(uuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
}

model AssetValuationSnapshot {
  id         String   @id @default(uuid())
  assetId    String?
  asset      Asset?   @relation(fields: [assetId], references: [id])
  areaCode   String?
  source     String
  title      String?
  listingUrl String?
  price      Decimal
  currency   String   @default("VND")
  landArea   Decimal?
  pricePerM2 Decimal?
  capturedAt DateTime
  rawPayload Json?
  createdAt  DateTime @default(now())

  @@index([assetId, capturedAt(sort: Desc)])
  @@index([areaCode, capturedAt(sort: Desc)])
  @@index([source, capturedAt(sort: Desc)])
}
